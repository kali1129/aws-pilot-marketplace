# aws-pilot MCP server config
# For local dev, .mcp.json passes these directly. For VPS, copy to .env and source.

AWS_PROFILE=default
AWS_REGION=us-east-1

# Mode: read-only | dry-run | execute
AWS_PILOT_MODE=dry-run

# Budget guardrail (USD/month)
AWS_PILOT_BUDGET_USD=50

# Audit log location
AWS_PILOT_AUDIT_LOG=/data/audit.jsonl

# For HTTP mode (VPS deploy)
PORT=8080
# Bearer token clients must send (set in plugin userConfig as mcp_auth_token)
AWS_PILOT_AUTH_TOKEN=change-me-to-a-random-secret
